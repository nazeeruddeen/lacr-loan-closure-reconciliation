                       "type":  "timeseries",
                       "title":  "Workflow P95 Latency (SLO)",
                       "gridPos":  {
                                       "h":  8,
                                       "w":  12,
                                       "x":  0,
                                       "y":  21
                                   },
                       "targets":  [
                                       {
                                           "expr":  "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"lacr-backend\",uri=~\"/api/v1/closure-requests.*|/api/v1/ops/.*\"}[5m])))",
                                           "refId":  "A"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "s",
                                                            "thresholds":  {
                                                                               "mode":  "absolute",
                                                                               "steps":  [
                                                                                             {
                                                                                                 "color":  "green",
                                                                                                 "value":  null
                                                                                             },
                                                                                             {
                                                                                                 "color":  "orange",
                                                                                                 "value":  1.5
                                                                                             },
                                                                                             {
                                                                                                 "color":  "red",
                                                                                                 "value":  2
                                                                                             }
                                                                                         ]
                                                                           }
                                                        }
                                       }
                   },
                   {
                       "id":  10,
                       "type":  "timeseries",
                       "title":  "Workflow 5xx Ratio (SLO)",
                       "gridPos":  {
                                       "h":  8,
                                       "w":  12,
                                       "x":  12,
                                       "y":  21
                                   },
                       "targets":  [
                                       {
                                           "expr":  "(sum(rate(http_server_requests_seconds_count{job=\"lacr-backend\",uri=~\"/api/v1/closure-requests.*|/api/v1/ops/.*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"lacr-backend\",uri=~\"/api/v1/closure-requests.*|/api/v1/ops/.*\"}[5m])), 0.001))",
                                           "refId":  "A"
                                       }
                                   ],
                       "fieldConfig":  {
                                           "defaults":  {
                                                            "unit":  "percentunit",
                                                            "thresholds":  {
                                                                               "mode":  "absolute",
                                                                               "steps":  [
                                                                                             {
