{
  "title": "LACR Backend Overview",
  "uid": "lacr-overview",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"lacr-backend\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Down" }, "1": { "text": "Up" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Failed Outbox Events",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "lacr_outbox_status_count{status=\"failed\"}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Stale Outbox Events",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "lacr_outbox_status_count{status=\"stale\"}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Mismatched Reconciliations",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "lacr_reconciliation_status_count{status=\"mismatched\"}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Closure Queue by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "lacr_closure_status_count", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Outbox Publish Status",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "lacr_outbox_status_count", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Settlement Exposure",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "lacr_amount", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyINR" } }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Failed Event Queue",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        { "expr": "lacr_failed_events_current_count", "refId": "A" }
      ]
    }
  ]
}
